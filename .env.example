# CanPlan 2.0 Mobile — example environment configuration.
#
# Copy this file to `.env.local` (git-ignored) and fill in real values.
# Only variables prefixed with EXPO_PUBLIC_ are exposed to the app at runtime.

# AWS AppSync GraphQL endpoint (required).
EXPO_PUBLIC_GRAPHQL_URL=https://YOUR-APP-ID.appsync-api.YOUR-REGION.amazonaws.com/graphql

# Cognito User Pool (required for sign-in / real API calls).
# These are the `UserPoolId` / `UserPoolClientId` CloudFormation outputs.
EXPO_PUBLIC_COGNITO_USER_POOL_ID=YOUR-REGION_XXXXXXXXX
EXPO_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# Once these are set, the app configures Amplify and registers an Amplify-backed
# auth token provider automatically (see src/features/auth). Sign in via the
# useSignIn() hook to obtain the Cognito ID token used as the Authorization header.
