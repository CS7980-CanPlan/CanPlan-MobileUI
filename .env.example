# CanPlan 2.0 Mobile — example environment configuration.
#
# Copy this file to `.env.local` (git-ignored) and fill in real values.
# Only variables prefixed with EXPO_PUBLIC_ are exposed to the app at runtime.

# AWS AppSync GraphQL endpoint (required).
EXPO_PUBLIC_GRAPHQL_URL=https://YOUR-APP-ID.appsync-api.YOUR-REGION.amazonaws.com/graphql

# NOTE: the app also requires a Cognito ID token provider to be registered at
# runtime (see src/api/authTokenProvider.ts) before API calls will succeed.
